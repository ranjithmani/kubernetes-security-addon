# Kyverno Helm Values - HA Configuration
# Generated by Ansible

# Admission Controller (main component)
admissionController:
  replicas: {{ kyverno_admission_replicas }}

  container:
    resources:
      limits:
        memory: {{ kyverno_admission_resources.limits.memory }}
      requests:
        cpu: {{ kyverno_admission_resources.requests.cpu }}
        memory: {{ kyverno_admission_resources.requests.memory }}

{% if kyverno_anti_affinity_enabled %}
  podAntiAffinity:
    preferredDuringSchedulingIgnoredDuringExecution:
      - weight: 100
        podAffinityTerm:
          labelSelector:
            matchExpressions:
              - key: app.kubernetes.io/component
                operator: In
                values:
                  - admission-controller
          topologyKey: kubernetes.io/hostname
{% endif %}

  podDisruptionBudget:
    enabled: true
    minAvailable: {{ kyverno_admission_pdb_min_available }}

# Background Controller
backgroundController:
  enabled: {{ kyverno_background_controller_enabled | lower }}
  replicas: {{ kyverno_background_replicas }}

  resources:
    limits:
      memory: {{ kyverno_background_resources.limits.memory }}
    requests:
      cpu: {{ kyverno_background_resources.requests.cpu }}
      memory: {{ kyverno_background_resources.requests.memory }}

{% if kyverno_anti_affinity_enabled %}
  podAntiAffinity:
    preferredDuringSchedulingIgnoredDuringExecution:
      - weight: 100
        podAffinityTerm:
          labelSelector:
            matchExpressions:
              - key: app.kubernetes.io/component
                operator: In
                values:
                  - background-controller
          topologyKey: kubernetes.io/hostname
{% endif %}

  podDisruptionBudget:
    enabled: true
    minAvailable: {{ kyverno_background_pdb_min_available }}

